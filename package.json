{
  "name": "biztrack-unified",
  "version": "3.0.0",
  "description": "BizTrack - Unified Business Management System",
  "main": "server-unified.js",
  "scripts": {
    "install-all": "npm install && cd frontend && npm install && cd ..",
    "build": "cd frontend && npm run build && cd ..",
    "start": "node server-unified.js",
    "dev": "nodemon server-unified.js",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm start",
    "postinstall": "cd frontend && npm install && npm run build"
  },
  "keywords": [
    "dashboard",
    "business",
    "biztrack",
    "unified"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "socket.io": "^4.6.1",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
}
